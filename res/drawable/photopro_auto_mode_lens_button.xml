<?xml version="1.0" encoding="utf-8"?>
<inset
  xmlns:android="http://schemas.android.com/apk/res/android">
    <layer-list>
        <item>
            <selector>
                <item android:state_activated="true">
                    <ripple android:color="#80ffffff">
                        <item android:id="@android:id/mask">
                            <shape android:shape="oval">
                                <size android:height="@dimen/auto_mode_zoom_circle_size" android:width="@dimen/auto_mode_zoom_circle_size" />
                                <solid android:color="@android:color/white" />
                            </shape>
                        </item>
                    </ripple>
                </item>
                <item android:state_activated="false">
                    <ripple android:color="#80ffffff">
                        <item android:id="@android:id/mask" android:top="@dimen/auto_mode_zoom_circle_margin" android:bottom="@dimen/auto_mode_zoom_circle_margin" android:start="@dimen/auto_mode_zoom_circle_margin" android:end="@dimen/auto_mode_zoom_circle_margin">
                            <shape android:shape="oval">
                                <size android:height="@dimen/auto_mode_zoom_circle_size_inner" android:width="@dimen/auto_mode_zoom_circle_size_inner" />
                                <solid android:color="@android:color/white" />
                            </shape>
                        </item>
                    </ripple>
                </item>
            </selector>
        </item>
        <item android:drawable="@drawable/photopro_lens_zoom_circle" android:top="@dimen/auto_mode_zoom_circle_margin" android:bottom="@dimen/auto_mode_zoom_circle_margin" android:start="@dimen/auto_mode_zoom_circle_margin" android:end="@dimen/auto_mode_zoom_circle_margin" />
    </layer-list>
</inset>
