<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:state_checked="true" android:color="@color/photopro_text_highlight_disabled" />
    <item android:state_checked="true" android:color="@color/photopro_text_highlight" />
    <item android:state_enabled="false" android:state_selected="true" android:color="@color/photopro_text_highlight_disabled" />
    <item android:state_selected="true" android:color="@color/photopro_text_highlight" />
    <item android:state_enabled="false" android:color="@color/photopro_text_highlight_disabled" android:state_activated="true" />
    <item android:color="@color/photopro_text_highlight" android:state_activated="true" />
    <item android:state_enabled="false" android:color="@color/photopro_text_primary_disabled" />
    <item android:color="@color/photopro_text_primary" />
</selector>
