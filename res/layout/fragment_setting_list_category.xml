<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="horizontal" android:id="@id/category_root" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout android:id="@id/image_background" android:layout_width="@dimen/settings_list_category_background" android:layout_height="fill_parent">
        <ImageView android:layout_gravity="center" android:id="@id/category_image" android:layout_width="@dimen/settings_list_category_icon" android:layout_height="@dimen/settings_list_category_icon" />
    </FrameLayout>
    <TextView android:textAppearance="@style/TextAppearance.PhotoPro.Setting.Menu.Category" android:gravity="center_vertical" android:id="@id/category_name" android:layout_width="wrap_content" android:layout_height="fill_parent" android:layout_marginStart="@dimen/settings_list_item_margin" android:layout_marginEnd="@dimen/settings_list_item_margin" />
</LinearLayout>
