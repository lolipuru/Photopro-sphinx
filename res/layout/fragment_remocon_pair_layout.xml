<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <ImageView android:id="@id/pair_controller_image" android:layout_width="fill_parent" android:layout_height="@dimen/settings_remote_control_pairing_image_height" android:src="@drawable/ble_remote_control_illust_pair_new_controller_icn" android:scaleType="centerCrop" android:adjustViewBounds="true" />
    <ScrollView android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:textAppearance="@style/TextAppearanceSettingsDetailDesc" android:gravity="start|center|top" android:id="@id/pair_controller_description" android:paddingTop="@dimen/settings_detail_desc_margin_top" android:paddingBottom="@dimen/settings_detail_desc_margin_bottom" android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="@string/ble_remote_control_pair_new_controller_description_txt" android:paddingStart="@dimen/settings_detail_desc_margin_start" android:paddingEnd="@dimen/settings_detail_desc_margin_end" />
